# Datenbankverbindung und grundlegende Verbindungseinstellungen.
DB_USER=
DB_PASSWORD=
DB_SERVER=
DB_DATABASE=
DB_PORT=
DB_ENCRYPT=
DB_TRUST_SERVER_CERT=
DB_REQUEST_TIMEOUT=
DB_CONNECTION_TIMEOUT=

# Logging-Level (z.B. error, warn, info, debug).
LOG_LEVEL=

# Filter fuer Gruppen.
FILTER_GROUP_ALLOWLIST=
FILTER_GROUP_BLOCKLIST=
FILTER_GROUPS_WITH_MATCHING_REGEX=
FILTER_GROUPS_NOT_MATCHING_REGEX=
FILTER_GROUPS_MIN_USERS=

# Filter fuer Benutzer.
FILTER_USERS_IGNORE_LOCKED=
FILTER_USERS_ALLOWLIST=
FILTER_USERS_BLOCKLIST=
FILTER_USERS_WITH_GROUP_ALLOWLIST=
FILTER_USERS_WITH_GROUP_BLOCKLIST=
FILTER_USERS_WITH_USERNAME_MATCHING_REGEX=
FILTER_USERS_WITH_USERNAME_NOT_MATCHING_REGEX=
FILTER_USERS_WITH_GROUPS_NOT_MATCHING_REGEX=

# Suffixe fuer returnvalue im Benutzer-XML:
# Gruppe: Standard `(g)` im Skript, Benutzer: Standard leer (wenn in `.env` nicht gesetzt).
RETURNVALUE_GROUP_SUFFIX=
RETURNVALUE_USER_SUFFIX=

# Ausgabeziele fuer die erzeugten XML-Dateien.
POSTAL_PATH_XML_USERS=
POSTAL_PATH_XML_GROUPS=

# XML-Attributsteuerung (z.B. fuer Sortierung durch enaio).
XML_SORTABLE=

# Optionale Sortierung fuer Gruppen.
GROUP_SORT_KEYWORDS_FIRST=
GROUP_SORT_ORDER=
GROUP_SORT_NUMERIC=

# Optionale Sortierung fuer Benutzer.
USER_SORT_KEYWORDS_FIRST=
USER_SORT_ORDER=
USER_SORT_BY=

# E-Mail-Benachrichtigung bei Fehlern.
EMAIL_ERROR_NOTIFICATION_TO=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=
EMAIL_USER=
EMAIL_PASSWORD=
